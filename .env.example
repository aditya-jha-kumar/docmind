# =============================================================================
# DocMind Environment Variables
# =============================================================================
# Copy this file to `.env.local` for local development:
#   cp .env.example .env.local
#
# NEVER commit `.env`, `.env.local`, or any file containing real secrets.
# On each machine, maintain your own `.env.local` (or use a secrets manager).
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL via Prisma)
# -----------------------------------------------------------------------------
# Local: postgresql://USER:PASSWORD@localhost:5432/docmind?schema=public&sslmode=verify-full
# Hosted (Neon): use sslmode=verify-full to avoid pg SSL deprecation warnings
DATABASE_URL=

# -----------------------------------------------------------------------------
# Google Gemini
# -----------------------------------------------------------------------------
# https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional model overrides (defaults shown)
# GEMINI_CHAT_MODEL=gemini-2.5-flash
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# GEMINI_EMBEDDING_DIMENSIONS=768
# CHAT_TEMPERATURE=0.5

# Performance tuning (optional)
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=100
# EMBEDDING_BATCH_SIZE=20
# EMBEDDING_PARALLEL_WAVES=3
# RETRIEVAL_TOP_K=6
# MIN_RELEVANCE_SCORE=0.35
# CHAT_HISTORY_LIMIT=12

# -----------------------------------------------------------------------------
# Pinecone (vector database)
# -----------------------------------------------------------------------------
# https://app.pinecone.io/
# Optional Pinecone serverless region (defaults: aws / us-east-1)
# PINECONE_CLOUD=aws
# PINECONE_REGION=us-east-1
PINECONE_API_KEY=
PINECONE_INDEX=

# -----------------------------------------------------------------------------
# Clerk (authentication)
# -----------------------------------------------------------------------------
# https://dashboard.clerk.com/
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional Clerk redirect URLs (defaults work for localhost:3000)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# -----------------------------------------------------------------------------
# UploadThing (file uploads)
# -----------------------------------------------------------------------------
# https://uploadthing.com/dashboard
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=

# -----------------------------------------------------------------------------
# Inngest (background jobs / workflows)
# -----------------------------------------------------------------------------
# https://app.inngest.com/
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Local Inngest dev server (optional — used with `npx inngest-cli dev`)
# INNGEST_DEV=1

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# NODE_ENV is set automatically by Next.js; do not override in .env.local
# NEXT_PUBLIC_APP_URL=http://localhost:3000
